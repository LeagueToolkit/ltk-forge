{
  "$schema": "https://raw.githubusercontent.com/nicoviii/tauri-v2-nightly-schema/main/schemas/2.2.0/desktop-schema.json",
  "productName": "LTK Forge",
  "version": "0.1.0",
  "identifier": "dev.leaguetoolkit.forge",
  "build": {
    "beforeDevCommand": "pnpm --filter @ltk-forge/app dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "pnpm --filter @ltk-forge/app build",
    "frontendDist": "../apps/forge/dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "LTK Forge",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "decorations": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: https://asset.localhost; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
